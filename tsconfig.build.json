{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "moduleResolution": "bundler"
  },
  "include": ["src/index.ts", "src/components/**/*"],
  "exclude": ["src/main.tsx", "src/App.tsx", "src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.stories.tsx"]
}
